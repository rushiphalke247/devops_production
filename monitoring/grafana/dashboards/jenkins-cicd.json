{
  "__inputs": [],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Jenkins CI/CD pipeline monitoring - Build status, queue, executor usage, and job metrics",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 300,
      "title": "Jenkins Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "title": "Jenkins Up",
      "type": "stat",
      "targets": [
        {
          "expr": "up{job=\"jenkins\"}",
          "legendFormat": "Status",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "title": "Queue Size",
      "type": "stat",
      "targets": [
        {
          "expr": "jenkins_queue_size_value",
          "legendFormat": "Queue",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "title": "Total Executors",
      "type": "stat",
      "targets": [
        {
          "expr": "jenkins_executor_count_value",
          "legendFormat": "Executors",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "title": "Busy Executors",
      "type": "stat",
      "targets": [
        {
          "expr": "jenkins_executor_in_use_value",
          "legendFormat": "In Use",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "title": "Nodes Online",
      "type": "stat",
      "targets": [
        {
          "expr": "jenkins_node_online_value",
          "legendFormat": "Nodes",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 301,
      "title": "Build Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Build Count Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "increase(jenkins_runs_total_total{status=\"SUCCESS\"}[1h])",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "increase(jenkins_runs_total_total{status=\"FAILURE\"}[1h])",
          "legendFormat": "Failure",
          "refId": "B"
        },
        {
          "expr": "increase(jenkins_runs_total_total{status=\"UNSTABLE\"}[1h])",
          "legendFormat": "Unstable",
          "refId": "C"
        },
        {
          "expr": "increase(jenkins_runs_total_total{status=\"ABORTED\"}[1h])",
          "legendFormat": "Aborted",
          "refId": "D"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Build Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jenkins_runs_total_total / 1000",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 302,
      "title": "Queue & Executors",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Queue Size Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jenkins_queue_size_value",
          "legendFormat": "Queue Size",
          "refId": "A"
        },
        {
          "expr": "jenkins_queue_blocked_value",
          "legendFormat": "Blocked",
          "refId": "B"
        },
        {
          "expr": "jenkins_queue_buildable_value",
          "legendFormat": "Buildable",
          "refId": "C"
        },
        {
          "expr": "jenkins_queue_stuck_value",
          "legendFormat": "Stuck",
          "refId": "D"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "spanNulls": true,
            "lineInterpolation": "stepAfter"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Executor Utilization",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jenkins_executor_count_value",
          "legendFormat": "Total Executors",
          "refId": "A"
        },
        {
          "expr": "jenkins_executor_in_use_value",
          "legendFormat": "In Use",
          "refId": "B"
        },
        {
          "expr": "jenkins_executor_free_value",
          "legendFormat": "Free",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 303,
      "title": "JVM Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "JVM Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "vm_memory_total_used",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "vm_memory_total_committed",
          "legendFormat": "Committed",
          "refId": "B"
        },
        {
          "expr": "vm_memory_total_max",
          "legendFormat": "Max",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [
        {
          "expr": "vm_thread_count",
          "legendFormat": "Thread Count",
          "refId": "A"
        },
        {
          "expr": "vm_daemon_count",
          "legendFormat": "Daemon Threads",
          "refId": "B"
        },
        {
          "expr": "vm_blocked_count",
          "legendFormat": "Blocked Threads",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["jenkins", "ci-cd", "devops"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Jenkins CI/CD",
  "uid": "jenkins-cicd",
  "version": 1
